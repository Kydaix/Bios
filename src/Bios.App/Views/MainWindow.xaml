<ui:FluentWindow x:Class="Bios.App.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:Bios.App.ViewModels"
                 Title="BIOS Tuner"
                 Width="1180" Height="780"
                 MinWidth="980" MinHeight="640"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="BIOS Tuner" />

        <Grid Grid.Row="1" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header: hardware + status -->
            <Border Grid.Row="0" Margin="16,4,16,8" Padding="18,14"
                    CornerRadius="10"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Optimiseur BIOS — ASUS X870-A / Ryzen 7 9800X3D"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="{Binding HardwareText}" Margin="0,4,0,0"
                               FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{Binding StatusText}" Margin="0,8,0,0"
                               FontSize="13"
                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Body: categories | tweaks -->
            <Grid Grid.Row="1" Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Categories -->
                <Border Grid.Column="0" Margin="0,0,8,0" Padding="6"
                        CornerRadius="10"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Catégories" Margin="10,8"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <ListBox ItemsSource="{Binding Categories}"
                                 SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="8" />
                                    <Setter Property="Margin" Value="2" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:CategoryViewModel}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <Border CornerRadius="4" Padding="6,1" Margin="0,4,0,0"
                                                    HorizontalAlignment="Left"
                                                    Background="{Binding RiskBrush}">
                                                <TextBlock Text="{Binding RiskLabel}" FontSize="10" Foreground="White" />
                                            </Border>
                                        </StackPanel>
                                        <Border Grid.Column="1" VerticalAlignment="Center"
                                                CornerRadius="9" MinWidth="18" Height="18" Padding="5,0"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding SelectedCount}" FontSize="10"
                                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- Tweaks of selected category -->
                <Border Grid.Column="1" Margin="8,0,0,0"
                        CornerRadius="10"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel DataContext="{Binding SelectedCategory}">
                            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="{Binding Description}" Margin="0,6,0,14" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                            <ItemsControl ItemsSource="{Binding Tweaks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:TweakViewModel}">
                                        <Border Margin="0,0,0,10" Padding="14" CornerRadius="8"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <ui:ToggleSwitch Grid.Column="0" Margin="0,2,14,0"
                                                                 VerticalAlignment="Top"
                                                                 IsChecked="{Binding IsSelected, Mode=TwoWay}" />

                                                <StackPanel Grid.Column="1">
                                                    <WrapPanel>
                                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                        <Border CornerRadius="4" Padding="6,1" Margin="10,0,0,0"
                                                                VerticalAlignment="Center"
                                                                Background="{Binding RiskBrush}">
                                                            <TextBlock Text="{Binding RiskLabel}" FontSize="10" Foreground="White" />
                                                        </Border>
                                                        <Border CornerRadius="4" Padding="6,1" Margin="6,0,0,0"
                                                                VerticalAlignment="Center"
                                                                Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}"
                                                                Visibility="{Binding Recommended, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="Recommandé" FontSize="10"
                                                                       Foreground="{DynamicResource SystemFillColorSuccessBrush}" />
                                                        </Border>
                                                        <Border CornerRadius="4" Padding="6,1" Margin="6,0,0,0"
                                                                VerticalAlignment="Center"
                                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                                Visibility="{Binding Verified, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="Vérifié" FontSize="10"
                                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                        </Border>
                                                    </WrapPanel>

                                                    <TextBlock Text="{Binding Description}" Margin="0,6,0,0" TextWrapping="Wrap"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                                    <TextBlock Text="{Binding DiffSummary}" Margin="0,8,0,0"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                                               Visibility="{Binding HasImport, Converter={StaticResource BoolToVis}}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Footer: actions -->
            <Border Grid.Row="2" Margin="16,8,16,12" Padding="14,10" CornerRadius="10"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ui:Button Grid.Column="0" Content="Importer le BIOS actuel"
                               Command="{Binding ImportCommand}" Appearance="Secondary" MinWidth="170" />

                    <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding SelectedChangeCount, StringFormat='{}{0} changement(s) sélectionné(s)'}" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <ui:Button Content="Recommandé" Command="{Binding SelectRecommendedCommand}" Margin="0,0,6,0" />
                        <ui:Button Content="Tout décocher" Command="{Binding ClearSelectionCommand}" Margin="0,0,6,0" />
                        <ui:Button Content="Aperçu" Command="{Binding PreviewCommand}" Margin="0,0,6,0" />
                        <ui:Button Content="Restaurer" Command="{Binding RestoreCommand}" Margin="0,0,6,0" />
                        <ui:Button Content="Appliquer" Command="{Binding ApplyCommand}" Appearance="Primary" MinWidth="120" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Busy overlay -->
            <Border Grid.Row="0" Grid.RowSpan="3"
                    Background="#AA000000"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ui:ProgressRing IsIndeterminate="True" Width="60" Height="60" />
                    <TextBlock Text="{Binding BusyMessage}" Margin="0,16,0,0"
                               FontSize="14" Foreground="White" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
